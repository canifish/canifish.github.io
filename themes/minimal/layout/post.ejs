<% if (page.password) { %>
  <%- partial('partial/encrypted') %>
<% } else { %>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title"><%= page.title %></h1>
      <time class="post-date" datetime="<%= date(page.date, 'YYYY-MM-DD') %>">
        <%= date(page.date, theme.post.date_format || 'YYYY-MM-DD') %>
      </time>
    </header>
    <div class="post-content">
      <%- page.content %>
    </div>
    <% if (page.tags && page.tags.length) { %>
      <div class="post-tags">
        <% page.tags.forEach(function(tag) { %>
          <a class="tag" href="<%- url_for(tag.path) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    <% } %>
  </article>
<% } %>
