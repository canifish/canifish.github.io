<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><% if (is_home()) { %><%= config.title %><% } else if (is_post()) { %><%= page.title %> - <%= config.title %><% } else { %><%= page.title || __('title.not_found') %> - <%= config.title %><% } %></title>
<meta name="description" content="<%= page.description || config.description %>">
<meta name="author" content="<%= config.author %>">
<link rel="stylesheet" href="<%- url_for('/css/style.css') %>">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📝</text></svg>">
<% if (theme.bg_image && theme.bg_image !== "''") { %>
<link rel="preload" as="image" href="<%- theme.bg_image %>">
<style>
  body {
    background-color: #3a3a4a;
    background-image: url('<%- theme.bg_image %>');
    background-size: cover;
    background-attachment: fixed;
    background-position: center;
  }
  .post-content, .post-item, .page-content, .archive, .password-prompt {
    background: rgba(255,255,255,0.88);
    border-radius: 8px;
    padding: 24px;
  }
  @media (prefers-color-scheme: dark) {
    body { background-color: #1a1a2e; }
    .post-content, .post-item, .page-content, .archive, .password-prompt {
      background: rgba(26,26,46,0.88);
    }
  }
</style>
<% } %>
