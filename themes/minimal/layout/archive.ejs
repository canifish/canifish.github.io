<div class="archive">
  <h1>Archives</h1>
  <% var year = 0 %>
  <% page.posts.each(function(post) { %>
    <% var postYear = date(post.date, 'YYYY') %>
    <% if (postYear !== year) { %>
      <% year = postYear %>
      <h2 class="archive-year"><%= year %></h2>
    <% } %>
    <div class="archive-item">
      <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'MM-DD') %></time>
      <a href="<%- url_for(post.path) %>"><%= post.title %></a>
      <% if (post.password) { %><span class="lock-icon"> 🔒</span><% } %>
    </div>
  <% }) %>
</div>
